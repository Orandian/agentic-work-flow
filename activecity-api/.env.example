# =============================================================
# ActiveCity API — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# =============================================================

# ----- Database (PostgreSQL) --------------------------------
# JDBC URL for your PostgreSQL instance.
# Example: jdbc:postgresql://localhost:5432/activecity_db
DB_URL=jdbc:postgresql://localhost:5432/activecity_db

# PostgreSQL username
DB_USERNAME=postgres

# PostgreSQL password
DB_PASSWORD=changeme

# ----- JWT --------------------------------------------------
# Secret key used to sign JWTs. Must be at least 32 characters.
# Generate a strong random value: openssl rand -base64 48
JWT_SECRET=replace-with-a-random-string-of-at-least-32-chars

# Token expiry in hours (default: 8)
JWT_EXPIRY_HOURS=8

# ----- SMTP / Mail ------------------------------------------
# SMTP server hostname (e.g., smtp.sendgrid.net, smtp.mailgun.org)
MAIL_HOST=smtp.sendgrid.net

# SMTP port — 587 for STARTTLS
MAIL_PORT=587

# SMTP login username (often the literal "apikey" for SendGrid)
MAIL_USERNAME=apikey

# SMTP password / API key
MAIL_PASSWORD=SG.replace-with-your-sendgrid-api-key

# ----- CORS -------------------------------------------------
# Allowed origin for the frontend application.
# Development default is http://localhost:3000.
CORS_ALLOWED_ORIGIN=http://localhost:3000
