<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.activecity.api.user.repository.UserProfileMapper">

    <resultMap id="profileResultMap" type="com.activecity.api.user.dto.ProfileDto">
        <id     property="id"         column="id"/>
        <result property="name"       column="full_name"/>
        <result property="email"      column="email"/>
        <result property="department" column="department"/>
        <result property="position"   column="position"/>
        <result property="userType"   column="role"/>
        <result property="createdAt"  column="created_at"/>
    </resultMap>

    <select id="findById" resultMap="profileResultMap">
        SELECT id, full_name, email, department, position, role,
               TO_CHAR(created_at, 'YYYY-MM-DD HH24:MI:SS') AS created_at
        FROM users
        WHERE id = #{id} AND delete_flg = 0
    </select>

    <update id="updateProfile">
        UPDATE users SET
            full_name  = #{name},
            department = #{department},
            position   = #{position},
            updated_at = NOW()
        WHERE id = #{id} AND delete_flg = 0
    </update>

</mapper>
