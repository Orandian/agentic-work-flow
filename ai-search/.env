APP_NAME=activecity-ai-search
APP_ENV=development
APP_PORT=8000

# Anthropic (primary LLM)
ANTHROPIC_API_KEY=sk-ant-...

# ChromaDB
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION=activecity-docs

# PostgreSQL (shared with Spring Boot backend)
DATABASE_URL=postgresql://activecity_user:activecity_pass@localhost:5433/activecity

# JWT (must match Spring Boot backend secret)
JWT_SECRET=8qqG2iYf53YWjJ4/e6TXGxOhr/dhLWbVIFJJ3MF44iAqZEc2NR0m0IW4/Adhx1ja
JWT_ALGORITHM=HS256

# Embedding model (runs locally via sentence-transformers)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# RAG config
RAG_TOP_K=5
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=50

# CORS
ALLOWED_ORIGINS=http://localhost:3000

# Upload limits
MAX_FILE_SIZE_MB=20
